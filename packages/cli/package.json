{
  "name": "@karnstack/reins",
  "version": "0.3.0",
  "description": "Drive your real, logged-in browsers from any coding agent: the reins CLI + local daemon, paired with the reins browser extension.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karnstack/reins.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/karnstack/reins#readme",
  "bugs": "https://github.com/karnstack/reins/issues",
  "keywords": [
    "browser",
    "automation",
    "chrome",
    "cdp",
    "agent",
    "skill",
    "cli"
  ],
  "bin": {
    "reins": "./dist/cli.js"
  },
  "files": [
    "dist",
    "extension",
    "sideload-key.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && node scripts/bundle-extension.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "tsdown && node scripts/bundle-extension.mjs"
  },
  "dependencies": {
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@reins/extension": "workspace:*",
    "@reins/protocol": "workspace:*",
    "@types/node": "26.0.1",
    "@types/ws": "8.18.1",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
