{
  "name": "@reins/extension",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch --mode development",
    "gen:icons": "node scripts/generate-icons.mjs",
    "zip": "vite build && node scripts/zip.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@reins/protocol": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.0",
    "@resvg/resvg-js": "2.6.2",
    "@types/chrome": "0.2.0",
    "@types/ws": "8.18.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "ws": "8.21.0"
  }
}
