{
  "name": "@karnstack/reins",
  "version": "0.2.0",
  "description": "One CLI for reins: a local MCP daemon that drives your real, logged-in browsers through the reins extension.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karnstack/reins.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/karnstack/reins#readme",
  "bugs": "https://github.com/karnstack/reins/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser",
    "automation",
    "chrome",
    "cdp",
    "agent"
  ],
  "bin": {
    "reins": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "tsdown"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@reins/protocol": "workspace:*",
    "@types/node": "26.0.1",
    "@types/ws": "8.18.1",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
